# URL pública (preview Vercel, domínio próprio). Use o mesmo host que o Google Search Console (ex.: www).
# SEO canônico padrão no código: https://www.simuladividendos.com
# NEXT_PUBLIC_SITE_URL=https://www.simuladividendos.com

